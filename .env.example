# --- Supabase ---
# Obtido em: https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEUPROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# --- Anthropic ---
# Obtido em: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Auth (gere uma string aleatória longa, ex: openssl rand -hex 32) ---
JWT_SECRET=troque_por_uma_string_aleatoria_longa_aqui_32chars_minimo

# --- Credenciais do usuário administrador ---
ADMIN_EMAIL=seuemail@exemplo.com
ADMIN_PASSWORD=SuaSenhaForte123!
